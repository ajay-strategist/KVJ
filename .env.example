# =============================================================================
# KVJ Analytics — environment template. Copy to `.env` and fill in.
# `.env` is gitignored — never commit real values.
# =============================================================================

# --- Supabase -----------------------------------------------------------------
# Project URL, e.g. https://abcdefghijklmno.supabase.co
# Find it in: Supabase dashboard → Project Settings → Data API → Project URL
VITE_SUPABASE_URL=

# Publishable (anon) key. This one is PUBLIC by design — it ships in the browser
# bundle and is protected by Row Level Security. Safe to put here.
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# NOT stored here:
#
#  * The Supabase service_role key — it bypasses RLS. It must never reach the
#    browser or this file. Server-side only.
#  * Any employee's mailbox password. Per-employee SMTP credentials are entered
#    by each employee in the app's own Mail Configuration screen and encrypted
#    at rest server-side. They never live in a file, in the repo, or in source.
# =============================================================================
